{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "outDir": "../dist-electron",
    "rootDir": ".",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ES2022",
    "lib": ["ES2022"],
    "sourceMap": true,
    "declaration": false,
    "types": ["node"]
  },
  "include": ["./**/*.ts", "./**/*.cts"],
  "exclude": ["../src"]
}
